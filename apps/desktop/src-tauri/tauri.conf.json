{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vanta",
  "version": "0.1.2",
  "identifier": "studio.vanta.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Vanta — Local Character Studio",
        "width": 1440,
        "height": 940,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "decorations": false,
        "resizable": true,
        "backgroundColor": "#09090D"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://127.0.0.1:*; img-src 'self' asset: data: blob:; media-src 'self' blob:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "externalBin": ["binaries/vanta-orchestrator"]
  }
}
